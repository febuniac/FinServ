# FinSecure Platform — Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ──────────────────────────────────────────────
# PostgreSQL Database
# ──────────────────────────────────────────────
DB_HOST=
DB_PORT=5432
DB_USER=finsecure
DB_PASSWORD=
DB_NAME=finsecure_db

# ──────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────
JWT_SECRET=

# ──────────────────────────────────────────────
# Stripe Payments
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
